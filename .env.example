# ============================================================
#  El Fogón Criollo — .env.example
#  Copiar como .env y ajustar valores
# ============================================================

NODE_ENV=development

# Base de datos
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fogon_criollo
DB_USER=postgres
DB_PASSWORD=CAMBIAR_EN_PRODUCCION
DB_POOL_MIN=2
DB_POOL_MAX=20

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CAMBIAR_EN_PRODUCCION

# JWT
JWT_SECRET=CAMBIAR_EN_PRODUCCION_minimo_32_caracteres
JWT_EXPIRES=8h

# Servidor
PORT=3000
CLIENT_URL=http://localhost

# Frontend
VITE_API_URL=/api
VITE_SOCKET_URL=/

# Exportaciones
EXPORT_DIR=/app/exports
MAX_EXPORT_ROWS=10000

# Backup automático de la base de datos
BACKUP_DIR=/app/backups
BACKUP_CRON=0 3 * * *
BACKUP_RETENTION_DAYS=7

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=10

# pgAdmin
PGADMIN_EMAIL=admin@fogon.local
PGADMIN_PASSWORD=admin123

# Logs
LOG_LEVEL=debug
